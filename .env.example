# OIDC is required for the management UI. The redirect URI is BASE_URL plus
# OIDC_CALLBACK_PATH.

# [Required] Authelia issuer URL
# OIDC_ISSUER_URL=https://auth.example.com

# [Required] Authelia OIDC client ID
# OIDC_CLIENT_ID=tgstate

# [Required] Authelia OIDC client secret
# OIDC_CLIENT_SECRET=

# [Optional] OIDC callback path (default: /api/auth/callback)
# OIDC_CALLBACK_PATH=/api/auth/callback

# [Optional] Public access URL used for share links and the OIDC callback URL.
# BASE_URL=https://your-domain.example

# [Optional] Telegram Bot Token from @BotFather
# BOT_TOKEN=

# [Optional] File storage channel (@channel_name or -100xxxxxxxxxx)
# CHANNEL_NAME=

# [Optional] Log level (default: info)
# LOG_LEVEL=info

# [Optional] Listen address (default: 0.0.0.0)
# HOST=127.0.0.1

# [Optional] Listen port (default: 8000)
# PORT=8000

# [Optional] Data directory (default: app/data)
# DATA_DIR=app/data
